# Copy values into Deno Deploy env settings (or export locally for `deno task dev`).
# Bearer token every request must present. Generate something long and random:
#   openssl rand -hex 24
KODER_TOKEN=

# Optional: lock CORS to the deployed board's origin (default is "*").
# KODER_ORIGIN=https://your-koder-board.example.com

# --- Static host (static.ts) — set these on the SECOND Deno Deploy app ---
# The sync API's URL and the same token as KODER_TOKEN above. static.ts injects
# them into js/config.local.js at request time so the token stays out of git.
# KODER_API_BASE=https://your-sync-app.deno.net
# KODER_API_TOKEN=
