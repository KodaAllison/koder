# Copy values into Deno Deploy env settings (or export locally for `deno task dev`).
# Bearer token every request must present. Generate something long and random:
#   openssl rand -hex 24
KODER_TOKEN=

# Optional: lock CORS to the deployed board's origin (default is "*"). The app
# serves the frontend same-origin, so this only matters if you point a separate
# external frontend at the API.
# KODER_ORIGIN=https://your-koder-board.example.com
